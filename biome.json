{
  "$schema": "https://biomejs.dev/schemas/2.4.13/schema.json",

  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },

  "formatter": {
    "indentStyle": "space",
    "indentWidth": 2
  },

  "html": {
    "experimentalFullSupportEnabled": true,
    "formatter": {
      "enabled": true
    }
  },

  "css": {
    "formatter": {
      "enabled": true
    }
  },

  "linter": {
    "rules": {
      "correctness": {
        "noUndeclaredVariables": "error"
      },
      "nursery": {
        "useBaseline": {
          "level": "error",
          "options": {
            "available": "newly"
          }
        }
      },
      "style": {
        "useConsistentTypeDefinitions": {
          "level": "error",
          "options": {
            "style": "type"
          }
        }
      }
    }
  }
}
