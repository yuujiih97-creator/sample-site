---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

export const prerender = true;

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      ogImagePath="/og/index.png"
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <img
          class="hero-image"
          src="https://images.unsplash.com/photo-1522623349500-de37a56ea2a5?fm=jpg&q=70&w=1600&auto=format&fit=crop"
          alt="紅葉に包まれた山門と歩く人のシルエット"
          loading="eager"
          decoding="async"
          width="1600"
          height="2000"
        >
        <p class="hero-credit">
          Photo by
          <a
            href="https://unsplash.com/@gaspanik"
            target="_blank"
            rel="noopener noreferrer"
            >Masaaki Komori</a
          >
          on
          <a
            href="https://unsplash.com/photos/silhouette-of-man-near-outside-qwPSnBvdhtI"
            target="_blank"
            rel="noopener noreferrer"
            >Unsplash</a
          >
        </p>
      </section>

      <section class="intro">
        <h1 class="site-name">{SITE_TITLE}</h1>
        <p class="bio">{SITE_DESCRIPTION}</p>
      </section>

      <section class="menu">
        <p class="section-label">カテゴリ</p>
        <ul class="menu-list">
          <li class="menu-item">
            <a href="/land/" class="menu-link">
              <span class="menu-title">土地</span>
              <span class="menu-desc">街の雰囲気や住みやすさ</span>
            </a>
          </li>
          <li class="menu-item">
            <a href="/people/" class="menu-link">
              <span class="menu-title">人柄</span>
              <span class="menu-desc">地域の人の特色や文化</span>
            </a>
          </li>
          <li class="menu-item">
            <a href="/gourmet/" class="menu-link">
              <span class="menu-title">グルメ</span>
              <span class="menu-desc">名物料理やおすすめの店</span>
            </a>
          </li>
          <li class="menu-item">
            <a href="/climate/" class="menu-link">
              <span class="menu-title">気候</span>
              <span class="menu-desc">季節ごとの天気と暮らし</span>
            </a>
          </li>
        </ul>
      </section>

      <section class="recent-posts">
        <p class="section-label">最近の投稿</p>
        <ul class="post-list">
          {posts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
        </ul>
        <a href="/blog" class="all-posts">すべての投稿を見る →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
main {
  max-width: 680px;
  margin: 0 auto;
  padding: 4rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 4rem;
}
.hero {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}
.hero-image {
  width: 100%;
  height: auto;
  max-height: 420px;
  object-fit: cover;
  border-radius: 12px;
  display: block;
}
.hero-credit {
  margin: 0;
  font-size: 0.75rem;
  color: rgb(var(--gray));
  text-align: right;
}
.hero-credit a {
  color: rgb(var(--gray));
  text-decoration: underline;
}
.hero-credit a:hover {
  color: rgb(var(--black));
}
.site-name {
  font-size: 1.75rem;
  margin: 0 0 0.75rem 0;
  font-weight: 700;
  line-height: 1.2;
}
.bio {
  margin: 0;
  color: rgb(var(--gray-dark));
  line-height: 1.7;
  font-size: 1rem;
}
.section-label {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgb(var(--gray));
  margin: 0 0 1rem 0;
}
.menu-list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 0.75rem;
}
.menu-item {
  list-style: none;
}
.menu-link {
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
  padding: 1.1rem 1.2rem;
  background: white;
  border: 1px solid rgb(var(--gray-light));
  border-radius: 10px;
  text-decoration: none;
  color: inherit;
  transition:
    border-color 0.15s,
    color 0.15s;
}
.menu-title {
  font-size: 1rem;
  font-weight: 700;
  color: rgb(var(--black));
  transition: color 0.15s;
}
.menu-desc {
  font-size: 0.85rem;
  color: rgb(var(--gray));
  line-height: 1.55;
}
.menu-link:hover {
  border-color: rgb(var(--accent));
}
.menu-link:hover .menu-title {
  color: rgb(var(--accent));
}
@media (max-width: 480px) {
  .menu-list {
    grid-template-columns: 1fr;
  }
}
.post-list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.post-item {
  list-style: none;
}
.post-item a {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid rgb(var(--gray-light));
  text-decoration: none;
  color: rgb(var(--black));
  transition: color 0.15s;
}
.post-item:first-child a {
  border-top: 1px solid rgb(var(--gray-light));
}
.post-item a:hover {
  color: rgb(var(--accent));
}
.post-title {
  font-size: 0.95rem;
}
.post-date {
  font-size: 0.8rem;
  color: rgb(var(--gray));
  white-space: nowrap;
  flex-shrink: 0;
}
.all-posts {
  display: inline-block;
  margin-top: 1.25rem;
  font-size: 0.875rem;
  color: rgb(var(--accent));
  text-decoration: none;
}
.all-posts:hover {
  text-decoration: underline;
}
</style>
