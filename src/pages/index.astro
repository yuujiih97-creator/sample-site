---
import { getCollection } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";

export const prerender = true;

const posts = (await getCollection("blog"))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead
      title={SITE_TITLE}
      description={SITE_DESCRIPTION}
      ogImagePath="/og/index.png"
    />
  </head>
  <body>
    <Header />
    <main>
      <section class="intro">
        <h1 class="site-name">{SITE_TITLE}</h1>
        <p class="bio">{SITE_DESCRIPTION}</p>
      </section>

      <section class="recent-posts">
        <p class="section-label">最近の投稿</p>
        <ul class="post-list">
          {posts.map((post) => (
						<li class="post-item">
							<a href={`/blog/${post.id}/`}>
								<span class="post-title">{post.data.title}</span>
								<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
							</a>
						</li>
					))}
        </ul>
        <a href="/blog" class="all-posts">すべての投稿を見る →</a>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
main {
  max-width: 680px;
  margin: 0 auto;
  padding: 4rem 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 4rem;
}
.site-name {
  font-size: 1.75rem;
  margin: 0 0 0.75rem 0;
  font-weight: 700;
  line-height: 1.2;
}
.bio {
  margin: 0;
  color: rgb(var(--gray-dark));
  line-height: 1.7;
  font-size: 1rem;
}
.section-label {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: rgb(var(--gray));
  margin: 0 0 1rem 0;
}
.post-list {
  list-style: none;
  margin: 0;
  padding: 0;
}
.post-item {
  list-style: none;
}
.post-item a {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  padding: 0.75rem 0;
  border-bottom: 1px solid rgb(var(--gray-light));
  text-decoration: none;
  color: rgb(var(--black));
  transition: color 0.15s;
}
.post-item:first-child a {
  border-top: 1px solid rgb(var(--gray-light));
}
.post-item a:hover {
  color: rgb(var(--accent));
}
.post-title {
  font-size: 0.95rem;
}
.post-date {
  font-size: 0.8rem;
  color: rgb(var(--gray));
  white-space: nowrap;
  flex-shrink: 0;
}
.all-posts {
  display: inline-block;
  margin-top: 1.25rem;
  font-size: 0.875rem;
  color: rgb(var(--accent));
  text-decoration: none;
}
.all-posts:hover {
  text-decoration: underline;
}
</style>
