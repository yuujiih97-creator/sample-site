---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";

type Props = CollectionEntry<"blog">["data"] & {
  ogImagePath?: string;
};

const { title, description, pubDate, updatedDate, heroImage, ogImagePath } =
  Astro.props;
---

<html lang="ja">
  <head>
    <BaseHead
      title={title}
      description={description}
      ogImagePath={ogImagePath}
    />
    <style>
    main {
      width: calc(100% - 2em);
      max-width: 100%;
      margin: 0;
    }
    .hero-image {
      width: 100%;
    }
    .hero-image img {
      display: block;
      margin: 0 auto;
      border-radius: 12px;
      box-shadow: var(--box-shadow);
    }
    .prose {
      width: 720px;
      max-width: calc(100% - 2em);
      margin: auto;
      padding: 1em;
      color: rgb(var(--gray-dark));
    }
    .title {
      margin-bottom: 1em;
      padding: 1em 0;
      text-align: center;
      line-height: 1;
    }
    .title h1 {
      margin: 0 0 0.5em 0;
    }
    .date {
      margin-bottom: 0.5em;
      color: rgb(var(--gray));
    }
    .last-updated-on {
      font-style: italic;
    }
    </style>
    <style is:global>
    .photo-gallery {
      display: flex;
      gap: 0.75rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      padding: 0.5rem 0 1.25rem 0;
      margin: 1.75rem 0;
      scrollbar-width: thin;
    }
    .photo-gallery > figure {
      flex: 0 0 100%;
      scroll-snap-align: start;
      margin: 0;
    }
    .photo-gallery > figure img {
      width: 100%;
      aspect-ratio: 4 / 3;
      object-fit: cover;
      border-radius: 10px;
      display: block;
      background: rgb(var(--gray-light));
    }
    .photo-gallery > figure figcaption {
      font-size: 0.85rem;
      color: rgb(var(--gray));
      margin-top: 0.5rem;
      line-height: 1.55;
      padding: 0 0.25rem;
    }
    .photo-gallery-dots {
      display: flex;
      justify-content: center;
      gap: 0.5rem;
      margin: -0.5rem 0 1.75rem 0;
    }
    .photo-gallery-dots > button {
      width: 8px;
      height: 8px;
      padding: 0;
      border: 0;
      border-radius: 50%;
      background: rgb(var(--gray-light));
      cursor: pointer;
      transition:
        background-color 0.2s,
        transform 0.2s;
    }
    .photo-gallery-dots > button:hover {
      background: rgb(var(--gray));
    }
    .photo-gallery-dots > button.active {
      background: rgb(var(--accent));
      transform: scale(1.25);
    }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        <div class="hero-image">
          {heroImage && <Image width={1020} height={510} src={heroImage} alt="" />}
        </div>
        <div class="prose">
          <div class="title">
            <div class="date">
              <FormattedDate date={pubDate} />
              {updatedDate && (
									<div class="last-updated-on">
										最終更新日：<FormattedDate date={updatedDate} />
									</div>
								)}
            </div>
            <h1>{title}</h1>
            <hr>
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
    <script>
    document.querySelectorAll(".photo-gallery").forEach((gallery) => {
      const el = gallery as HTMLElement;
      const figures = Array.from(
        el.querySelectorAll("figure"),
      ) as HTMLElement[];
      if (figures.length === 0) return;
      let paused = false;

      // Build dot indicators
      const dots = document.createElement("div");
      dots.className = "photo-gallery-dots";
      const dotButtons: HTMLButtonElement[] = [];
      figures.forEach((_, idx) => {
        const dot = document.createElement("button");
        dot.type = "button";
        dot.setAttribute("aria-label", `${idx + 1}枚目を表示`);
        if (idx === 0) dot.classList.add("active");
        dot.addEventListener("click", () => {
          const target = figures[idx];
          if (target) {
            el.scrollTo({
              left: target.offsetLeft - el.offsetLeft,
              behavior: "smooth",
            });
          }
        });
        dots.appendChild(dot);
        dotButtons.push(dot);
      });
      el.parentNode?.insertBefore(dots, el.nextSibling);

      const updateActiveDot = () => {
        const galleryRect = el.getBoundingClientRect();
        let activeIdx = 0;
        let minDistance = Infinity;
        figures.forEach((fig, idx) => {
          const figRect = fig.getBoundingClientRect();
          const distance = Math.abs(figRect.left - galleryRect.left);
          if (distance < minDistance) {
            minDistance = distance;
            activeIdx = idx;
          }
        });
        dotButtons.forEach((dot, idx) => {
          dot.classList.toggle("active", idx === activeIdx);
        });
      };

      const advance = () => {
        if (paused) return;
        const firstFigure = figures[0];
        const currentScroll = el.scrollLeft;
        const maxScroll = el.scrollWidth - el.clientWidth;
        const figureWidth = firstFigure.offsetWidth + 12;
        if (currentScroll >= maxScroll - 10) {
          el.scrollTo({ left: 0, behavior: "smooth" });
        } else {
          el.scrollBy({ left: figureWidth, behavior: "smooth" });
        }
      };

      setInterval(advance, 4000);
      el.addEventListener("scroll", updateActiveDot, { passive: true });

      el.addEventListener("mouseenter", () => {
        paused = true;
      });
      el.addEventListener("mouseleave", () => {
        paused = false;
      });
      el.addEventListener(
        "touchstart",
        () => {
          paused = true;
        },
        { passive: true },
      );
      el.addEventListener("touchend", () => {
        setTimeout(() => {
          paused = false;
        }, 3000);
      });
    });
    </script>
  </body>
</html>
